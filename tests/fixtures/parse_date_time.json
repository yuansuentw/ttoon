{
  "description": "Date, time, and datetime parsing and validation",
  "tests": [
    {
      "id": "date_basic",
      "description": "Basic date: 2024-01-01",
      "input": "[2024-01-01]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "date",
            "value": "2024-01-01"
          }
        ]
      }
    },
    {
      "id": "date_end_of_year",
      "description": "End of year: 2024-12-31",
      "input": "[2024-12-31]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "date",
            "value": "2024-12-31"
          }
        ]
      }
    },
    {
      "id": "date_leap_year",
      "description": "Leap year: 2000-02-29",
      "input": "[2000-02-29]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "date",
            "value": "2000-02-29"
          }
        ]
      }
    },
    {
      "id": "date_last_day_1999",
      "description": "Last day of 1999: 1999-12-31",
      "input": "[1999-12-31]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "date",
            "value": "1999-12-31"
          }
        ]
      }
    },
    {
      "id": "time_midnight",
      "description": "Time midnight: 00:00:00",
      "input": "[00:00:00]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "time",
            "value": "00:00:00"
          }
        ]
      }
    },
    {
      "id": "time_end_of_day",
      "description": "Time end of day: 23:59:59",
      "input": "[23:59:59]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "time",
            "value": "23:59:59"
          }
        ]
      }
    },
    {
      "id": "time_fractional_1",
      "description": "Time fractional 1 digit: 23:59:59.1",
      "input": "[23:59:59.1]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "time",
            "value": "23:59:59.1"
          }
        ]
      }
    },
    {
      "id": "time_fractional_2",
      "description": "Time fractional 2 digits: 23:59:59.12",
      "input": "[23:59:59.12]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "time",
            "value": "23:59:59.12"
          }
        ]
      }
    },
    {
      "id": "time_fractional_3",
      "description": "Time fractional 3 digits: 23:59:59.123",
      "input": "[23:59:59.123]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "time",
            "value": "23:59:59.123"
          }
        ]
      }
    },
    {
      "id": "time_fractional_6",
      "description": "Time fractional 6 digits (max): 23:59:59.123456",
      "input": "[23:59:59.123456]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "time",
            "value": "23:59:59.123456"
          }
        ]
      }
    },
    {
      "id": "datetime_utc",
      "description": "DateTime with UTC timezone",
      "input": "[2024-01-01T00:00:00Z]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "datetime",
            "value": "2024-01-01T00:00:00Z"
          }
        ]
      }
    },
    {
      "id": "datetime_offset_zero",
      "description": "DateTime with +00:00 offset",
      "input": "[2024-01-01T00:00:00+00:00]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "datetime",
            "value": "2024-01-01T00:00:00+00:00"
          }
        ]
      }
    },
    {
      "id": "datetime_offset_positive",
      "description": "DateTime with +08:00 offset",
      "input": "[2024-01-01T00:00:00+08:00]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "datetime",
            "value": "2024-01-01T00:00:00+08:00"
          }
        ]
      }
    },
    {
      "id": "datetime_offset_negative",
      "description": "DateTime with -05:00 offset",
      "input": "[2024-01-01T00:00:00-05:00]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "datetime",
            "value": "2024-01-01T00:00:00-05:00"
          }
        ]
      }
    },
    {
      "id": "datetime_offset_boundary_max",
      "description": "DateTime with +23:59 offset (boundary)",
      "input": "[2024-01-01T00:00:00+23:59]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "datetime",
            "value": "2024-01-01T00:00:00+23:59"
          }
        ]
      }
    },
    {
      "id": "datetime_offset_boundary_min",
      "description": "DateTime with -12:00 offset (boundary)",
      "input": "[2024-01-01T00:00:00-12:00]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "datetime",
            "value": "2024-01-01T00:00:00-12:00"
          }
        ]
      }
    },
    {
      "id": "datetime_with_fractional",
      "description": "DateTime with fractional seconds",
      "input": "[2024-01-01T00:00:00.123456Z]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "datetime",
            "value": "2024-01-01T00:00:00.123456Z"
          }
        ]
      }
    },
    {
      "id": "datetime_full_valid",
      "description": "Valid date, time, datetime combination",
      "input": "[2024-12-31, 23:59:59, 23:59:59.123456, 2024-12-31T23:59:59Z]",
      "expected": {
        "type": "list",
        "value": [
          {
            "type": "date",
            "value": "2024-12-31"
          },
          {
            "type": "time",
            "value": "23:59:59"
          },
          {
            "type": "time",
            "value": "23:59:59.123456"
          },
          {
            "type": "datetime",
            "value": "2024-12-31T23:59:59Z"
          }
        ]
      }
    }
  ]
}
